vim.lsp.config("vue_ls", {
	init_options = {
		vue = {
			hybridMode = false,
		},
	},
})

vim.lsp.enable({ "lua_ls", "ts_ls", "vue_ls", "eslint", "pylsp", "html", "cssls", "marksman" })
